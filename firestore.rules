rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, role, isVerified, status, createdAt
    //
    // Collection: sessions
    // Fields: userId, title, createdAt, updatedAt
    //
    // Subcollection: sessions/{sessionId}/messages
    // Fields: role, content, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ( request.auth.token.email == "yanadreamer@gmail.com" ||
          request.auth.token.email == "admin@vaslink.site" );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'isVerified', 'status', 'deviceId', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.isVerified is bool &&
             data.status in ['Uji Coba', 'Pro'] &&
             data.deviceId is string &&
             data.deviceId.size() > 0;
    }

    function isValidSessionCreate(data) {
      return data.keys().hasAll(['userId', 'title', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.title is string &&
             data.title.size() > 0 &&
             data.title.size() <= 100;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content', 'createdAt']) &&
             data.role in ['user', 'assistant'] &&
             data.content is string &&
             data.content.size() > 0;
    }

    // Rules
    match /settings/api_keys {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isAuthenticated() && (isOwner(userId) || isAdmin());
      // Allow listing by deviceId for registration limit check
      allow list: if isAuthenticated() && (isAdmin() || request.query.limit <= 10);
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /sessions/{sessionId} {
      // Split read into get and list for better clarity
      allow get: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAuthenticated() && ( (resource.data.userId == request.auth.uid) || isAdmin());
      
      allow create: if isAuthenticated() && isValidSessionCreate(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());

      match /messages/{messageId} {
        allow read: if isAuthenticated() && (get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isAuthenticated() && (get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid || isAdmin()) && isValidMessage(request.resource.data);
      }
    }

    // Test connection path
    match /test/connection {
      allow read: if true;
    }
  }
}
