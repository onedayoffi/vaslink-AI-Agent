{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "isVerified": { "type": "boolean" },
        "status": { "type": "string", "enum": ["Uji Coba", "Pro"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "isVerified", "status"]
    },
    "Session": {
      "title": "Session",
      "description": "A chat session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "role", "content", "createdAt"]
    },
    "AppSetting": {
      "title": "AppSetting",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "geminiApiKey": { "type": "string" },
        "deepseekApiKey": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/settings/{settingId}": {
      "schema": "AppSetting",
      "description": "Global settings documents"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents"
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Chat session documents"
    },
    "/sessions/{sessionId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a session"
    }
  }
}
